+    def test_file_path_field_callable_path_no_changes(self):
+        """Identical callable/partial paths on FilePathField produce no migration."""
+        def _filepath_callable():
+            return '/some/path/'
+
+        def filepath_callable(key, **kwargs):
+            return functools.partial(_filepath_callable, key, **kwargs)
+
+        before = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable('dir'))),
+        ])]
+        after = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable('dir'))),
+        ])]
+        changes = self.get_changes(before, after)
+        self.assertNumberMigrations(changes, 'testapp', 0)
+
+    def test_file_path_field_callable_path_changed(self):
+        """Changed partial arguments on FilePathField.path produce AlterField."""
+        def _filepath_callable(instance, filename, key, **kwargs):
+            return '{}/{}'.format(instance, filename)
+
+        def filepath_callable(key, **kwargs):
+            return functools.partial(_filepath_callable, key, **kwargs)
+
+        before = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable('dir'))),
+        ])]
+        args_changed = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable('other-dir'))),
+        ])]
+        changes = self.get_changes(before, args_changed)
+        self.assertNumberMigrations(changes, 'testapp', 1)
+        self.assertOperationTypes(changes, 'testapp', 0, ['AlterField'])
+

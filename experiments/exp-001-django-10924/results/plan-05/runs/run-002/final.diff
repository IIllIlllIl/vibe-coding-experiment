+    def test_file_path_field_callable_path(self):
+        def filepath_callable():
+            return '/some/path'
+
+        def filepath_callable_wrapper(key):
+            return functools.partial(filepath_callable, key)
+
+        # Identical callable path — no migration.
+        before = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable)),
+        ])]
+        after = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable)),
+        ])]
+        changes = self.get_changes(before, after)
+        self.assertNumberMigrations(changes, 'testapp', 0)
+
+        # Identical partial — no migration.
+        before_partial = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable_wrapper('file'))),
+        ])]
+        after_partial = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable_wrapper('file'))),
+        ])]
+        changes = self.get_changes(before_partial, after_partial)
+        self.assertNumberMigrations(changes, 'testapp', 0)
+
+        # Changed partial arguments — migration generated.
+        args_changed = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=filepath_callable_wrapper('other'))),
+        ])]
+        changes = self.get_changes(before_partial, args_changed)
+        self.assertNumberMigrations(changes, 'testapp', 1)
+        self.assertOperationTypes(changes, 'testapp', 0, ['AlterField'])
+

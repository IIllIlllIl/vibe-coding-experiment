+    def test_file_path_field_callable_path(self):
+        def _filepath():
+            return '/some/path'
+
+        def filepath(key=None):
+            return functools.partial(_filepath) if key is None else key
+
+        # Identical callable path produces no migration.
+        before = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=_filepath)),
+        ])]
+        after = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=_filepath)),
+        ])]
+        changes = self.get_changes(before, after)
+        self.assertNumberMigrations(changes, 'testapp', 0)
+
+    def test_file_path_field_partial_path(self):
+        def _filepath(sub=''):
+            return '/some/path/' + sub
+
+        # Identical partial path produces no migration.
+        before = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=functools.partial(_filepath, 'a'))),
+        ])]
+        after = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=functools.partial(_filepath, 'a'))),
+        ])]
+        changes = self.get_changes(before, after)
+        self.assertNumberMigrations(changes, 'testapp', 0)
+
+        # Changed partial arguments produce AlterField.
+        args_changed = [ModelState("testapp", "Author", [
+            ("id", models.AutoField(primary_key=True)),
+            ("fp", models.FilePathField(path=functools.partial(_filepath, 'b'))),
+        ])]
+        changes = self.get_changes(before, args_changed)
+        self.assertNumberMigrations(changes, 'testapp', 1)
+        self.assertOperationTypes(changes, 'testapp', 0, ['AlterField'])
+

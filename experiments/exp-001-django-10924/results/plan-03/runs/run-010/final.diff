+def _get_test_path():
+    return os.path.join(PATH, 'filepathfield_test_dir') + '/'
+
+
+class FilePathFieldCallablePathTest(SimpleTestCase):
+    def test_callable_path_resolved_in_formfield(self):
+        """Callable path is resolved when creating the form field, not at model field init."""
+        model_field = models.FilePathField(path=_get_test_path)
+        # The model field stores the callable, not the evaluated string.
+        self.assertIs(model_field.path, _get_test_path)
+        # formfield() evaluates the callable and passes the resolved string.
+        form_field = model_field.formfield()
+        self.assertIsInstance(form_field.path, str)
+        self.assertIn('filepathfield_test_dir', form_field.path)

+    def test_callable_path(self):
+        """A callable path is resolved when the form field is created."""
+        from django.db import models as db_models
+        field = db_models.FilePathField(path=lambda: self.path)
+        # self.path is the callable, not the resolved string
+        self.assertTrue(callable(field.path))
+        # formfield() resolves the callable
+        form_field = field.formfield()
+        self.assertEqual(form_field.path, self.path)
